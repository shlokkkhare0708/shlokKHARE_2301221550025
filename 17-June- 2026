#include <stdio.h>

int main() {
    int num, temp, rev = 0, rem;

    printf("Enter a number: ");
    scanf("%d", &num);

    temp = num;

    if(num < 0) {
        printf("Not a palindrome\n");
        return 0;
    }

    while(num != 0) {
        rem = num % 10;
        rev = rev * 10 + rem;
        num = num / 10;
    }

    if(temp == rev) {
        printf("Palindrome number\n");
    }
    else {
        printf("Not a palindrome\n");
    }

    return 0;
}



